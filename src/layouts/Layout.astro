---
import { websiteConfig } from '../config/website.config.js';
import Navigation from '../components/Navigation.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import Footer from '../components/Footer.astro';
import LoadingSpinner from '../components/LoadingSpinner.astro';
import BackToTop from '../components/BackToTop.astro';

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || websiteConfig.site.description} />
    <meta name="keywords" content={websiteConfig.site.keywords} />
    <meta name="author" content={websiteConfig.site.author} />
    
    <title>{title ? `${title} - ${websiteConfig.site.title}` : websiteConfig.site.title}</title>

    <!-- 预加载字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.cn">
    <link rel="preconnect" href="https://fonts.gstatic.cn" crossorigin>
    <link rel="preconnect" href="https://p3.music.126.net">
    <link rel="preload" href="https://fonts.googleapis.cn/css2?family=Noto+Sans+SC:wght@400;500;600;700;800&family=Quicksand:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <link rel="stylesheet" href="/styles/mdi.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="/styles/mdi.css"></noscript>
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- 字体配置 -->
    <script>
        // 暴露字体配置给前端
        window.websiteConfig = {
            fonts: {
                main: {
                    family: '像素体',
                    file: '/fonts/像素体.ttf',
                    fallback: "'Quicksand', 'Noto Sans SC', sans-serif",
                    weight: 'normal'
                },
                title: {
                    family: '像素体',
                    file: '/fonts/像素体.ttf',
                    fallback: "'Quicksand', 'Noto Sans SC', sans-serif",
                    weight: 'bold'
                }
            }
        };
    </script>

    <!-- 网页图标配置 -->
    {websiteConfig.favicon.enabled && (
      <>
        <link rel="icon" type="image/x-icon" href={websiteConfig.favicon.default} />
        
        <!-- 不同尺寸图标 -->
        {websiteConfig.favicon.sizes["16x16"] && (
          <link rel="icon" type="image/png" sizes="16x16" href={websiteConfig.favicon.sizes["16x16"]} />
        )}
        {websiteConfig.favicon.sizes["32x32"] && (
          <link rel="icon" type="image/png" sizes="32x32" href={websiteConfig.favicon.sizes["32x32"]} />
        )}
        {websiteConfig.favicon.sizes["192x192"] && (
          <link rel="icon" type="image/png" sizes="192x192" href={websiteConfig.favicon.sizes["192x192"]} />
        )}
        {websiteConfig.favicon.sizes["512x512"] && (
          <link rel="icon" type="image/png" sizes="512x512" href={websiteConfig.favicon.sizes["512x512"]} />
        )}
        
        <!-- Apple Touch图标 -->
        {websiteConfig.favicon.appleTouch && (
          <link rel="apple-touch-icon" sizes="180x180" href={websiteConfig.favicon.appleTouch} />
        )}
      </>
    )}

    <!-- 主题脚本 -->
    <script>
        (function() {
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
            var last = 0, nav = document.getElementById('navbar');
            window.addEventListener('scroll', function() {
                var s = window.pageYOffset || document.documentElement.scrollTop;
                if (s > last && s > 100) nav && nav.classList.add('hidden');
                else if (s < last && s < 50) nav && nav.classList.remove('hidden');
                last = s;
            });
            // 主题切换
            var toggle = document.getElementById('theme-toggle');
            if (toggle) toggle.addEventListener('click', function() {
                var cur = document.documentElement.getAttribute('data-theme');
                var next = cur === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
            });
        })();
    </script>
</head>

<body>
    <!-- 加载动画 -->
    <LoadingSpinner />
    
    <!-- 背景图片容器 -->
    <div class="background-container" 
         data-bg-images={JSON.stringify(websiteConfig.background.images)}>
        <div 
            id="background-image" 
            class="background-image" 
            style={`background-image: url(${websiteConfig.background.defaultImage});`}
        ></div>
        <div class="background-overlay"></div>
    </div>
    
    <!-- 导航栏 -->
    <Navigation />
    
    <!-- 主内容区域 -->
    <div class="main-content">
        <slot />
    </div>
    
    <!-- 一键到顶按钮 -->
    <BackToTop />
    
    <!-- 音乐播放器 -->
    <MusicPlayer />
    
    <!-- 页脚 -->
    <Footer />
    
    <!-- 全局脚本 -->
    <script is:inline src="/scripts/fonts.js"></script>
    <script is:inline src="/scripts/theme.js"></script>
    <script is:inline src="/scripts/navigation.js"></script>
    <script is:inline src="/scripts/loading.js"></script>

    <!-- 背景随机化 — DOM 就绪后执行 -->
    <script>
        (function() {
            var c = document.querySelector('.background-container');
            var imgs = c ? JSON.parse(c.dataset.bgImages || '[]') : [];
            var bg = document.getElementById('background-image');
            if (imgs.length && bg) {
                bg.style.backgroundImage = 'url(' + imgs[Math.floor(Math.random() * imgs.length)] + ')';
                requestAnimationFrame(function() { bg.classList.add('active'); });
            }
        })();
    </script>
</body>
</html>