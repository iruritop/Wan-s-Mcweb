---
import { ViewTransitions } from 'astro:transitions';
import { websiteConfig } from '../config/website.config.js';
import Navigation from '../components/Navigation.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import Footer from '../components/Footer.astro';
import LoadingSpinner from '../components/LoadingSpinner.astro';
import BackToTop from '../components/BackToTop.astro';

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || websiteConfig.site.description} />
    <meta name="keywords" content={websiteConfig.site.keywords} />
    <meta name="author" content={websiteConfig.site.author} />
    
    <title>{title ? `${title} - ${websiteConfig.site.title}` : websiteConfig.site.title}</title>

    <!-- 页面过渡动画 -->
    <ViewTransitions />

    <!-- 预加载字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700;800&family=Quicksand:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    
    <!-- 图标库 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font@latest/css/materialdesignicons.min.css">
    
    <!-- 样式 -->
    <link rel="stylesheet" href="/styles/global.css" />
    
    <!-- 字体配置 -->
    <script>
        // 暴露字体配置给前端
        window.websiteConfig = {
            fonts: {
                main: {
                    family: '像素体',
                    file: '/fonts/像素体.ttf',
                    fallback: "'Quicksand', 'Noto Sans SC', sans-serif",
                    weight: 'normal'
                },
                title: {
                    family: '像素体',
                    file: '/fonts/像素体.ttf',
                    fallback: "'Quicksand', 'Noto Sans SC', sans-serif",
                    weight: 'bold'
                }
            }
        };
    </script>

    <!-- 网页图标配置 -->
    {websiteConfig.favicon.enabled && (
      <>
        <link rel="icon" type="image/x-icon" href={websiteConfig.favicon.default} />
        
        <!-- 不同尺寸图标 -->
        {websiteConfig.favicon.sizes["16x16"] && (
          <link rel="icon" type="image/png" sizes="16x16" href={websiteConfig.favicon.sizes["16x16"]} />
        )}
        {websiteConfig.favicon.sizes["32x32"] && (
          <link rel="icon" type="image/png" sizes="32x32" href={websiteConfig.favicon.sizes["32x32"]} />
        )}
        {websiteConfig.favicon.sizes["192x192"] && (
          <link rel="icon" type="image/png" sizes="192x192" href={websiteConfig.favicon.sizes["192x192"]} />
        )}
        {websiteConfig.favicon.sizes["512x512"] && (
          <link rel="icon" type="image/png" sizes="512x512" href={websiteConfig.favicon.sizes["512x512"]} />
        )}
        
        <!-- Apple Touch图标 -->
        {websiteConfig.favicon.appleTouch && (
          <link rel="apple-touch-icon" sizes="180x180" href={websiteConfig.favicon.appleTouch} />
        )}
      </>
    )}

    <!-- 主题脚本 -->
    <script>
        // 初始化主题
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            
            // 从数据属性获取背景图片配置
            const bgContainer = document.querySelector('.background-container');
            const bgImages = bgContainer ? JSON.parse(bgContainer.dataset.bgImages || '[]') : [];
            
            // 随机选择一张背景图片
            function initializeRandomBackground() {
                const backgroundImage = document.getElementById('background-image');
                if (bgImages.length > 0 && backgroundImage) {
                    // 随机选择一张图片
                    const randomIndex = Math.floor(Math.random() * bgImages.length);
                    const randomImage = bgImages[randomIndex];
                    
                    // 设置背景图片
                    backgroundImage.style.backgroundImage = `url(${randomImage})`;
                    
                    // 显示背景
                    setTimeout(() => {
                        backgroundImage.classList.add('active');
                    }, 100);
                }
            }
            
            // 初始化背景
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initializeRandomBackground);
            } else {
                initializeRandomBackground();
            }
            
            // 导航栏自动隐藏
            
            // 导航栏自动隐藏
            let lastScrollTop = 0;
            const navbar = document.getElementById('navbar');
            
            window.addEventListener('scroll', () => {
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                
                if (scrollTop > lastScrollTop && scrollTop > 100) {
                    // 向下滚动，隐藏导航栏
                    navbar?.classList.add('hidden');
                } else if (scrollTop < lastScrollTop && scrollTop < 50) {
                    // 向上滚动到顶部附近，显示导航栏
                    navbar?.classList.remove('hidden');
                }
                
                lastScrollTop = scrollTop;
            });
        })();
    </script>
</head>

<body>
    <!-- 加载动画 -->
    <LoadingSpinner />
    
    <!-- 背景图片容器 -->
    <div class="background-container" 
         data-bg-images={JSON.stringify(websiteConfig.background.images)}>
        <div 
            id="background-image" 
            class="background-image" 
            style={`background-image: url(${websiteConfig.background.defaultImage});`}
        ></div>
        <div class="background-overlay"></div>
    </div>
    
    <!-- 导航栏 -->
    <Navigation />
    
    <!-- 主内容区域 -->
    <main class="main-content">
        <slot />
    </main>
    
    <!-- 一键到顶按钮 -->
    <BackToTop />
    
    <!-- 音乐播放器 -->
    <MusicPlayer />
    
    <!-- 页脚 -->
    <Footer />
    
    <!-- 全局脚本 -->
    <script is:inline src="/scripts/fonts.js"></script>
    <script is:inline src="/scripts/theme.js"></script>
    <script is:inline src="/scripts/navigation.js"></script>
    <script is:inline src="/scripts/loading.js"></script>
</body>
</html>