---
import Layout from '../layouts/Layout.astro';
import { websiteConfig } from '../config/website.config.js';
import { getGalleryData, extractCategories } from '../utils/galleryApi.js';
import PageTitle from '../components/PageTitle.astro';

const title = "游戏相册";
const description = "浏览服务器的精彩游戏截图和玩家作品";

// 获取相册数据
const galleryImages = await getGalleryData(websiteConfig.gallery);

// 自动提取分类
const categories = extractCategories(galleryImages);
---

<Layout {title} {description}>
    <div class="page-container">
        <!-- 页面头部 -->
        <PageTitle pageTitle={websiteConfig.navigation.items.find(item => item.path === "/gallery")?.pageTitle} />

        <!-- 主要内容区域 -->
        <main class="page-content">
            <!-- 分类筛选 -->
            <section class="gallery-filters">
                <div class="filter-buttons">
                    {categories.map(category => (
                        <button 
                            class="filter-btn {category === '全部' ? 'active' : ''}" 
                            data-category={category}
                        >
                            {category}
                        </button>
                    ))}
                </div>
            </section>

            <!-- 相册网格 -->
            <section class="gallery-grid">
                {galleryImages.map(image => (
                    <div class="gallery-item card" data-category={image.category}>
                        <div class="gallery-image-container">
                            <img
                                src={image.thumbnailUrl}
                                alt={image.description}
                                class="gallery-image"
                                loading="lazy"
                                decoding="async"
                                data-fullsize={image.imageUrl}
                            />
                            <div class="gallery-overlay">
                                <button class="view-btn" data-image={image.imageUrl}>
                                    <i class="mdi mdi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="gallery-info">
                            <h3 class="gallery-title">{image.description}</h3>
                            <p class="gallery-description">{image.date}</p>
                            <div class="gallery-meta">
                                <span class="gallery-category">{image.category}</span>
                                <span class="gallery-date">{image.date}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </section>

            <!-- 提示信息 -->
            <div class="gallery-end-message">
                <i class="mdi mdi-emoticon-sad-outline"></i>
                <p>已经没有更多了(T＿T)  快进服创造属于你的精彩瞬间吧！</p>
            </div>
        </main>

        <!-- 大图查看模态框 -->
        <div id="image-modal" class="image-modal">
            <div class="modal-content">
                <span class="close-modal">&times;</span>
                <div class="modal-image-container">
                    <button class="nav-btn prev-btn">
                        <i class="mdi mdi-chevron-left"></i>
                    </button>
                    <img id="modal-image" src="" alt="" loading="lazy" decoding="async" />
                    <button class="nav-btn next-btn">
                        <i class="mdi mdi-chevron-right"></i>
                    </button>
                </div>
                <div class="modal-info">
                    <h3 id="modal-title"></h3>
                    <p id="modal-date"></p>
                    <p id="modal-category" class="modal-category"></p>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
.page-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
}

/* 分类筛选 */
.gallery-filters {
    display: flex;
    justify-content: center;
    margin-bottom: 2.5rem;
}
.filter-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    justify-content: center;
}
.filter-btn {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    padding: 0.6rem 1.3rem;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s var(--ease-spring);
    backdrop-filter: blur(10px);
}
.filter-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.filter-btn.active {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: white;
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

/* 相册瀑布流网格 */
.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.8rem;
}
.gallery-item {
    background: var(--color-card-bg);
    backdrop-filter: var(--glass-backdrop);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    transition: all 0.4s var(--ease-smooth);
    display: flex;
    flex-direction: column;
}
.gallery-item:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary);
}

/* 图片容器 — 自适应高度 */
.gallery-image-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--glass-bg);
}
.gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-smooth), filter 0.6s;
    filter: brightness(0.95);
}
.gallery-item:hover .gallery-image {
    transform: scale(1.08);
    filter: brightness(1.05);
}

/* 悬浮遮罩 — 渐变+描述 */
.gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.15) 50%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.2rem;
    opacity: 0;
    transition: opacity 0.35s var(--ease-smooth);
}
.gallery-item:hover .gallery-overlay { opacity: 1; }
.view-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    padding: 0.6rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s var(--ease-spring);
    transform: translateY(10px);
}
.gallery-item:hover .view-btn { transform: translateY(0); }
.view-btn:hover {
    background: var(--color-accent);
    transform: scale(1.08) !important;
    box-shadow: var(--shadow-md);
}

/* 信息区 */
.gallery-info {
    padding: 1.2rem 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
}
.gallery-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.gallery-description {
    color: var(--color-text-light);
    font-size: 0.82rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.gallery-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    padding-top: 0.35rem;
    border-top: 1px solid var(--glass-border);
    margin-top: auto;
}
.gallery-category {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.72rem;
}
.gallery-date {
    color: var(--color-text-light);
    font-size: 0.72rem;
}

/* 提示信息样式 */
.gallery-end-message {
    text-align: center;
    margin-top: 3rem;
}

.gallery-end-message i {
    font-size: 2.5rem;
    color: var(--color-text-light);
    display: block;
    margin-bottom: 0.8rem;
    opacity: 0.5;
}

.gallery-end-message p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.6;
    margin: 0;
}

/* 大图查看模态框样式 */
.image-modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(15px);
    animation: fadeIn 0.3s ease-out;
}

.modal-content {
    position: relative;
    margin: auto;
    max-width: 90%;
    max-height: 90%;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
}

.modal-image-container {
        position: relative;
        max-width: 100%;
        max-height: 70vh;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-xl);
        background: var(--color-background);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-content img {
        width: 100%;
        height: auto;
        max-height: 70vh;
        object-fit: contain;
        display: block;
    }

    /* 导航按钮样式 */
    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid var(--color-border);
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--color-primary);
        font-size: 1.5rem;
        transition: all 0.3s ease;
        z-index: 1001;
        backdrop-filter: blur(10px);
    }

    .nav-btn:hover {
        background: var(--color-primary);
        color: white;
        transform: translateY(-50%) scale(1.1);
        box-shadow: var(--shadow-md);
    }

    .prev-btn {
        left: 20px;
    }

    .next-btn {
        right: 20px;
    }

    /* 移动端导航按钮样式 */
    @media (max-width: 768px) {
        .nav-btn {
            width: 40px;
            height: 40px;
            font-size: 1.2rem;
        }

        .prev-btn {
            left: 10px;
        }

        .next-btn {
            right: 10px;
        }
    }

.close-modal {
    position: absolute;
    top: 20px;
    right: 20px;
    color: var(--color-text);
    font-size: 28px;
    font-weight: bold;
    cursor: pointer;
    z-index: 1001;
    background: var(--color-card);
    border: 2px solid var(--color-border);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
}

.close-modal:hover {
    background: var(--color-primary);
    color: white;
    transform: scale(1.1);
    box-shadow: var(--shadow-md);
}

.modal-info {
    background: var(--color-card);
    color: var(--color-text);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 600px;
    box-sizing: border-box;
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
}

.modal-info h3 {
    margin: 0 0 1rem 0;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: 0.5rem;
}

.modal-info p {
    margin: 0.75rem 0;
    font-size: 1rem;
    line-height: 1.5;
}

.modal-category {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1.1rem;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* 响应式设计 */
@media (max-width: 768px) {
    .gallery-grid {
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.2rem;
    }
    .gallery-image-container { aspect-ratio: 3/2; }
    .filter-buttons { gap: 0.4rem; }
    .filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.78rem;
    }
    .gallery-info { padding: 1rem 0.85rem; }
    .gallery-title { font-size: 0.95rem; }
    .modal-content {
        width: 95%;
        max-width: 95%;
        max-height: 90%;
        gap: 0.5rem;
    }
    .modal-image-container { max-height: 50vh; }
    .modal-info { padding: 1rem; max-width: 100%; }
    .modal-info h3 { font-size: 1.2rem; }
    .modal-info p { font-size: 0.9rem; }
    .close-modal {
        top: 10px; right: 10px;
        width: 36px; height: 36px;
        font-size: 20px;
    }
}

@media (max-width: 640px) {
    .gallery-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.8rem;
    }
    .gallery-image-container { aspect-ratio: 1/1; }
    .filter-btn {
        padding: 0.4rem 0.85rem;
        font-size: 0.72rem;
    }
    .gallery-info { padding: 0.75rem 0.6rem; }
    .gallery-title { font-size: 0.82rem; }
    .gallery-meta { font-size: 0.65rem; }
}

@media (max-width: 480px) {
    .gallery-grid {
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
    }
    .gallery-image-container { aspect-ratio: 1/1; }
    .gallery-info { padding: 0.75rem 0.65rem; }
    .gallery-title { font-size: 0.8rem; }
    .gallery-description { font-size: 0.7rem; -webkit-line-clamp: 1; }
    .gallery-meta { font-size: 0.65rem; }
    .gallery-category { font-size: 0.65rem; padding: 0.15rem 0.5rem; }
    .modal-content { width: 98%; max-width: 98%; }
    .modal-image-container { max-height: 45vh; }
    .modal-info { padding: 0.75rem; }
    .modal-info h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
    .modal-info p { font-size: 0.85rem; margin: 0.5rem 0; }
}

@media (max-width: 399px) {
    .gallery-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    .gallery-image-container { aspect-ratio: 16/10; }
    .gallery-info { padding: 0.85rem; }
    .gallery-title { font-size: 0.9rem; }
    .gallery-description { font-size: 0.75rem; -webkit-line-clamp: 2; }
}
</style>

<script>
// 相册筛选功能
document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;
    
    console.log('相册筛选功能初始化');
    console.log('筛选按钮数量:', filterButtons.length);
    console.log('相册项目数量:', galleryItems.length);
    
    // 分类筛选功能
    filterButtons.forEach(button => {
        button.addEventListener('click', function() {
            console.log('点击分类按钮:', this.textContent);
            
            // 移除所有按钮的active类
            filterButtons.forEach(btn => {
                btn.classList.remove('active');
                console.log('移除active类:', btn.textContent);
            });
            
            // 添加当前按钮的active类
            this.classList.add('active');
            console.log('添加active类:', this.textContent);
            
            const category = this.dataset.category;
            console.log('筛选分类:', category);
            
            // 筛选相册项目
            galleryItems.forEach(item => {
                const itemCategory = item.dataset.category;
                console.log('项目分类:', itemCategory, '匹配:', category === '全部' || itemCategory === category);
                
                if (category === '全部' || itemCategory === category) {
                    item.style.display = 'block';
                    console.log('显示项目:', itemCategory);
                } else {
                    item.style.display = 'none';
                    console.log('隐藏项目:', itemCategory);
                }
            });
            
            console.log('筛选完成');
        });
    });
    
    // 初始显示所有项目并激活"全部"按钮
    console.log('初始显示所有相册项目');
    galleryItems.forEach(item => {
        item.style.display = 'block';
    });
    
    // 设置"全部"按钮为激活状态
    const allButton = Array.from(filterButtons).find(btn => btn.dataset.category === '全部');
    if (allButton) {
        allButton.classList.add('active');
        console.log('设置"全部"按钮为激活状态');
    }
    
    // 初始化大图查看功能
    initImageModal();
});

// 大图查看功能
function initImageModal() {
    const modal = document.getElementById('image-modal') as HTMLElement;
    const modalImg = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title') as HTMLElement;
    const modalDate = document.getElementById('modal-date') as HTMLElement;
    const modalCategory = document.getElementById('modal-category') as HTMLElement;
    const closeBtn = document.querySelector('.close-modal') as HTMLElement;
    const prevBtn = document.querySelector('.prev-btn') as HTMLElement;
    const nextBtn = document.querySelector('.next-btn') as HTMLElement;
    
    // 存储所有图片数据
    let currentIndex = 0;
    let imageData = [];
    
    // 收集所有图片数据
    function collectImageData() {
        imageData = [];
        document.querySelectorAll('.view-btn').forEach((btn, index) => {
            const imageUrl = btn.getAttribute('data-image');
            const galleryItem = btn.closest('.gallery-item');
            
            const titleElement = galleryItem?.querySelector('.gallery-title');
            const dateElement = galleryItem?.querySelector('.gallery-date');
            const categoryElement = galleryItem?.querySelector('.gallery-category');
            
            const title = titleElement?.textContent || '未知标题';
            const date = dateElement?.textContent || '未知日期';
            const category = categoryElement?.textContent || '未知分类';
            
            imageData.push({
                index: index,
                imageUrl: imageUrl,
                title: title,
                date: date,
                category: category
            });
        });
    }
    
    // 显示指定索引的图片
    function showImage(index: number) {
        if (index < 0 || index >= imageData.length) return;
        
        const data = imageData[index];
        modalImg.src = data.imageUrl;
        modalTitle.textContent = data.title;
        modalDate.textContent = `日期：${data.date}`;
        modalCategory.textContent = `分类：${data.category}`;
        currentIndex = index;
        
        // 更新导航按钮状态
        prevBtn.style.display = index === 0 ? 'none' : 'flex';
        nextBtn.style.display = index === imageData.length - 1 ? 'none' : 'flex';
    }
    
    // 控制页面滚动
    function disableScroll() {
        document.body.style.overflow = 'hidden';
        document.body.style.position = 'relative';
        document.body.style.height = '100vh';
    }
    
    function enableScroll() {
        document.body.style.overflow = '';
        document.body.style.position = '';
        document.body.style.height = '';
    }

    // 点击查看大图按钮
    document.querySelectorAll('.view-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            collectImageData();
            const imageUrl = this.getAttribute('data-image');
            
            // 找到当前点击的图片索引
            const clickedIndex = imageData.findIndex(data => data.imageUrl === imageUrl);
            if (clickedIndex !== -1) {
                showImage(clickedIndex);
                modal.style.display = 'block';
                disableScroll();
            }
        });
    });

    // 上一张图片
    prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
            showImage(currentIndex - 1);
        }
    });

    // 下一张图片
    nextBtn.addEventListener('click', () => {
        if (currentIndex < imageData.length - 1) {
            showImage(currentIndex + 1);
        }
    });

    // 键盘导航
    document.addEventListener('keydown', (e) => {
        if (modal.style.display === 'block') {
            if (e.key === 'ArrowLeft' && currentIndex > 0) {
                showImage(currentIndex - 1);
            } else if (e.key === 'ArrowRight' && currentIndex < imageData.length - 1) {
                showImage(currentIndex + 1);
            } else if (e.key === 'Escape') {
                modal.style.display = 'none';
                enableScroll();
            }
        }
    });

    // 关闭模态框
    closeBtn.addEventListener('click', () => {
        modal.style.display = 'none';
        enableScroll();
    });

    // 点击模态框背景关闭
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.style.display = 'none';
            enableScroll();
        }
    });
}
</script>