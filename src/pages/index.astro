---
import Layout from '../layouts/Layout.astro';
import { websiteConfig } from '../config/website.config.js';
import PageTitle from '../components/PageTitle.astro';

const title = "主页";
const description = "欢迎来到我们的Minecraft服务器";
---

<Layout {title} {description}>
    <div class="page-container">
        <!-- 页面头部 -->
        <PageTitle pageTitle={websiteConfig.navigation.items.find(item => item.path === "/")?.pageTitle} />

        <!-- 欢迎引导区块 -->
        <section class="welcome-guide">
            <div class="guide-grid">
                <div class="guide-card">
                    <div class="guide-icon"><i class="mdi mdi-content-copy"></i></div>
                    <div class="guide-step">01</div>
                    <h2>复制地址</h2>
                    <p>点击下方「复制」按钮获取服务器 IP</p>
                </div>
                <div class="guide-card">
                    <div class="guide-icon"><i class="mdi mdi-account-multiple-plus"></i></div>
                    <div class="guide-step">02</div>
                    <h2>加入游戏</h2>
                    <p>打开 PCL 启动器，导入乌托邦整合包粘贴地址即可进入</p>
                </div>
                <div class="guide-card">
                    <div class="guide-icon"><i class="mdi mdi-castle"></i></div>
                    <div class="guide-step">03</div>
                    <h2>开始冒险</h2>
                    <p>探索方块世界，创造属于你的乌托邦之旅</p>
                </div>
            </div>
        </section>

        <!-- 主要内容区域 -->
        <main class="page-content">
            <!-- 服务器信息卡片 -->
            <section class="server-info-section">
                <div class="server-info-card card">
                    <!-- 服务器地址 -->
                    <div class="server-address">
                        <div class="address-label">
                            <i class="mdi mdi-network"></i>
                            <span>服务器地址</span>
                        </div>
                        <div class="address-container">
                            <code id="serverAddress">{websiteConfig.server.displayAddress}</code>
                            <button id="copyAddressBtn" class="copy-btn">
                                <i class="mdi mdi-content-copy"></i>
                                <span>复制</span>
                            </button>
                        </div>
                    </div>

                    <!-- 实时状态 -->
                    <div class="server-stats">
                        <div class="stat-item">
                            <i class="mdi mdi-account-group"></i>
                            <div class="stat-info">
                                <div class="stat-label">在线玩家</div>
                                <div class="stat-value" id="onlinePlayers">—</div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <i class="mdi mdi-cube"></i>
                            <div class="stat-info">
                                <div class="stat-label">游戏版本</div>
                                <div class="stat-value" id="gameVersion">{websiteConfig.server.version}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 服务器状态详情 -->
            <section class="server-status-section">
                <div class="server-status-card card">
                    <div class="status-header">
                        <h2 class="status-title">
                            <i class="mdi mdi-server"></i>
                            服务器实时状态
                        </h2>
                        <button id="refreshStatusBtn" class="refresh-btn">
                            <i class="mdi mdi-refresh"></i>
                            <span>刷新</span>
                        </button>
                    </div>

                    <!-- 状态指示器 -->
                    <div class="status-indicator">
                        <div class="server-icon-container">
                            <img id="serverIcon" class="server-icon" src="" alt="服务器图标" />
                        </div>
                        <div class="status-dot" id="serverStatusDot"></div>
                        <span class="status-text" id="serverStatusText">正在连接...</span>
                    </div>

                    <!-- 服务器信息 -->
                    <div class="server-details">
                        <div class="detail-row">
                            <div class="detail-label">服务器版本</div>
                            <div class="detail-value" id="versionDisplay">—</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">在线玩家</div>
                            <div class="detail-value" id="playersDisplay">—</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">服务器MOTD</div>
                            <div class="detail-value motd" id="motdDisplay">—</div>
                        </div>
                    </div>

                    <!-- 在线玩家列表 -->
                    <div class="players-section" id="playersSection">
                        <h3 class="players-title">当前在线玩家</h3>
                        <div class="players-list" id="playersList">
                            <div class="loading-players">加载中...</div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</Layout>

<script define:vars={{ apiEndpoint: websiteConfig.server.apiEndpoint, apiAddress: websiteConfig.server.apiAddress, port: websiteConfig.server.port }}>
// 服务器状态API调用
document.addEventListener('DOMContentLoaded', async function() {
    // 获取所有DOM元素
    const onlinePlayersEl = document.getElementById('onlinePlayers');
    const copyAddressBtn = document.getElementById('copyAddressBtn');
    const serverAddress = document.getElementById('serverAddress');
    const refreshStatusBtn = document.getElementById('refreshStatusBtn');
    const serverIcon = document.getElementById('serverIcon');
    const serverStatusDot = document.getElementById('serverStatusDot');
    const serverStatusText = document.getElementById('serverStatusText');
    const versionDisplay = document.getElementById('versionDisplay');
    const playersDisplay = document.getElementById('playersDisplay');
    const motdDisplay = document.getElementById('motdDisplay');
    const playersList = document.getElementById('playersList');
    
    
    if (!onlinePlayersEl) {
        console.error('找不到onlinePlayers元素');
        return;
    }
    
    // 复制服务器地址功能
    if (copyAddressBtn) {
        copyAddressBtn.addEventListener('click', async function() {
            const text = serverAddress.textContent;
            const originalText = copyAddressBtn.querySelector('span').textContent;
            
            try {
                await navigator.clipboard.writeText(text);
            } catch (e) {
                // fallback for HTTP/non-secure contexts
                const ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed'; ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
            }
            
            // 始终显示反馈 — 不管复制成功与否
            copyAddressBtn.querySelector('span').textContent = '已复制';
            copyAddressBtn.classList.add('copied');
            
            const toast = document.createElement('div');
            toast.className = 'copy-toast';
            toast.textContent = '✓ 地址已复制';
            document.body.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add('show'));
            
            setTimeout(() => {
                copyAddressBtn.querySelector('span').textContent = originalText;
                copyAddressBtn.classList.remove('copied');
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 2000);
        });
    }
    
    // 手动刷新服务器状态
    if (refreshStatusBtn) {
        refreshStatusBtn.addEventListener('click', async function() {
            const icon = refreshStatusBtn.querySelector('i');
            
            // 添加旋转动画
            refreshStatusBtn.disabled = true;
            icon.classList.add('spinning');
            
            await fetchServerStatus();
            
            // 移除旋转动画
            refreshStatusBtn.disabled = false;
            icon.classList.remove('spinning');
        });
    }
    
    // 设置加载状态
    function setLoadingState() {
        if (serverStatusText) serverStatusText.textContent = '正在连接...';
        if (serverStatusDot) {
            serverStatusDot.className = 'status-dot';
            serverStatusDot.style.animation = 'pulse 2s infinite';
        }
        if (serverIcon) {
            serverIcon.src = '';
            serverIcon.style.display = 'none';
        }
        if (versionDisplay) versionDisplay.textContent = '—';
        if (playersDisplay) playersDisplay.textContent = '—';
        if (motdDisplay) motdDisplay.textContent = '加载中...';
        if (playersList) playersList.innerHTML = '<div class="loading-players">加载中...</div>';
    }
    
    // 设置离线状态
    function setOfflineState() {
        if (serverStatusText) serverStatusText.textContent = '服务器离线';
        if (serverStatusDot) {
            serverStatusDot.className = 'status-dot offline';
            serverStatusDot.style.animation = 'none';
        }
        if (serverIcon) {
            serverIcon.src = '/assets/load/Obsidian.webp';
            serverIcon.style.display = 'block';
            serverIcon.style.opacity = '0.4';
        }
        if (versionDisplay) versionDisplay.textContent = '—';
        if (playersDisplay) playersDisplay.textContent = '0/?';
        if (motdDisplay) motdDisplay.textContent = '服务器当前不可用';
        if (playersList) playersList.innerHTML = '<div class="no-players">服务器暂无玩家在线(在线列表不显示假人)</div>';
    }
    
    // 更新服务器状态UI
    function updateServerStatusUI(data) {
        if (data.online) {
            if (serverStatusText) serverStatusText.textContent = '服务器在线';
            if (serverStatusDot) {
                serverStatusDot.className = 'status-dot online';
                serverStatusDot.style.animation = 'none';
            }
            
            // 更新服务器头像
            if (serverIcon && data.icon) {
                serverIcon.src = data.icon;
                serverIcon.style.display = 'block';
                serverIcon.style.opacity = '1';
                serverIcon.alt = '服务器图标';
            }
            
            // 更新版本信息
            if (versionDisplay) versionDisplay.textContent = data.version?.name_clean || '—';
            
            // 更新玩家信息
            const onlinePlayers = data.players?.online || 0;
            const maxPlayers = data.players?.max || '?';
            if (playersDisplay) playersDisplay.textContent = `${onlinePlayers}/${maxPlayers}`;
            
            // 更新MOTD
            if (motdDisplay) motdDisplay.textContent = data.motd?.clean || '—';
            
            // 更新在线玩家列表（过滤掉Anonymous Player）
            if (playersList) {
                const players = data.players?.list || [];
                
                if (players.length > 0) {
                    const playerItems = players.map(player => 
                        `<div class="player-item">
                            <img src="https://crafthead.net/avatar/${encodeURIComponent(player.name_clean)}" alt="" class="player-face" loading="lazy" onerror="this.style.display='none'">
                            <span class="player-name">${player.name_clean}</span>
                        </div>`
                    ).join('');
                    playersList.innerHTML = playerItems || '<div class="no-players">服务器暂无玩家在线(在线列表不显示假人)</div>';
                }
            }
        } else {
            setOfflineState();
        }
    }
    
    // 获取服务器状态
    async function fetchServerStatus() {
        setLoadingState();
        
        const OPANEL = 'https://opanel.coul.top:16666/open-api/players';
        const TOKEN = 'o-HRvF6bJrE3iuCtcGcl7uF4fZKHHGNJl38qOFZHZR8FmNRRWm';
        let data = null;
        
        // 优先 OPanel
        try {
            const res = await fetch(OPANEL, { headers: { 'Authorization': 'Bearer ' + TOKEN }, signal: AbortSignal.timeout(5000) });
            if (res.ok) {
                const raw = await res.json();
                const online = (raw.players || []).filter(p => p.isOnline).map(p => ({ name_clean: p.name }));
                data = {
                    online: true,
                    players: { online: online.length, max: 15, list: online },
                    version: { name_clean: '1.20.1' },
                    motd: { clean: '乌托邦探险之旅' },
                    icon: null
                };
            }
        } catch(e) {}
        
        // 降级 mcapi.us
        if (!data) {
            try {
                const res = await fetch(`https://mcapi.us/server/status?ip=${apiAddress}&port=${port}`, { headers: { 'Accept': 'application/json' }, signal: AbortSignal.timeout(8000) });
                if (res.ok) {
                    const raw = await res.json();
                    data = {
                        online: raw.online || false,
                        players: { online: raw.players?.now || 0, max: raw.players?.max || '?', list: (raw.players?.sample || []).map(p => ({ name_clean: p.name })) },
                        version: { name_clean: raw.server?.name || '—' },
                        motd: { clean: raw.motd || '—' },
                        icon: raw.favicon || null
                    };
                }
            } catch(e) {}
        }
        
        if (data) {
            if (data.online) {
                onlinePlayersEl.textContent = `${data.players?.online || 0}/${data.players?.max || '?'}`;
            } else {
                onlinePlayersEl.textContent = '离线';
            }
            updateServerStatusUI(data);
        } else {
            onlinePlayersEl.textContent = '—';
            if (serverStatusText) serverStatusText.textContent = '状态获取失败';
            if (serverStatusDot) { serverStatusDot.className = 'status-dot'; serverStatusDot.style.background = 'var(--color-warning)'; }
            if (serverIcon) { serverIcon.src = '/assets/load/Obsidian.webp'; serverIcon.style.display = 'block'; serverIcon.style.opacity = '0.5'; }
        }
    }
    
    // 初始获取状态（不阻塞页面渲染）
    fetchServerStatus();
    
    // 每60秒更新一次状态
    setInterval(fetchServerStatus, 60000);
});
</script>

<style>
/* 欢迎引导区块 */
.welcome-guide {
    max-width: 800px;
    margin: 0 auto 1.5rem;
}

.guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
}

.guide-card {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-backdrop);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1rem;
    text-align: center;
    transition: all 0.35s var(--ease-spring);
    position: relative;
    overflow: hidden;
}

.guide-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.35s var(--ease-smooth);
}

.guide-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
}

.guide-card:hover::before {
    transform: scaleX(1);
}

.guide-icon {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
}

.guide-step {
    font-family: '像素体', monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    background: rgba(255, 209, 102, 0.2);
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.5rem;
}

.guide-card h2 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.3rem;
}

.guide-card p {
    font-size: 0.78rem;
    color: var(--color-text-light);
    line-height: 1.4;
    margin: 0;
}

@media (max-width: 640px) {
    .guide-grid {
        grid-template-columns: 1fr;
        gap: 0.8rem;
    }
    .guide-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-align: left;
        padding: 1rem 1.2rem;
    }
    .guide-icon { font-size: 1.5rem; margin-bottom: 0; flex-shrink: 0; }
    .guide-step { margin-bottom: 0; flex-shrink: 0; font-size: 0.65rem; padding: 0.1rem 0.4rem; }
    .guide-card h2 { font-size: 0.9rem; white-space: nowrap; flex-shrink: 0; }
    .guide-card p { font-size: 0.72rem; }
}

.page-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}
.welcome-guide {
    max-width: 800px;
    margin: 0 auto 0.5rem;
}

.server-info-section {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
}

.server-info-card {
    text-align: center;
    background: linear-gradient(135deg, var(--glass-bg), var(--color-card-bg));
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
}

.server-address {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--glass-border);
}

.address-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
}

.address-label i {
    font-size: 1.5rem;
    color: var(--color-primary);
}

.address-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
}

#serverAddress {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 1rem 2rem;
    font-family: 'Courier New', monospace;
    font-size: 1.4rem;
    color: var(--color-text);
    font-weight: 700;
    min-width: 200px;
    text-align: center;
    box-shadow: var(--shadow-sm);
}

.copy-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s var(--ease-smooth);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 120px;
    justify-content: center;
}

.copy-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.copy-btn.copied {
    background: var(--color-success);
    transform: scale(1.05);
}

/* Toast 提示 */
.copy-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    background: var(--color-success);
    color: white;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: var(--shadow-lg);
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s var(--ease-spring);
}

.copy-toast.show {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
}

.server-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
}

.stat-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-align: left;
    padding: 1.5rem 1.2rem;
    background: linear-gradient(135deg, rgba(255, 142, 183, 0.08), rgba(166, 227, 233, 0.06));
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
    transition: all 0.35s var(--ease-spring);
    position: relative;
    overflow: hidden;
}

.stat-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 142, 183, 0.05));
    opacity: 0;
    transition: opacity 0.3s;
}

.stat-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
}

.stat-item:hover::after {
    opacity: 1;
}

.stat-item i {
    font-size: 2.5rem;
    color: var(--color-primary);
    flex-shrink: 0;
    background: rgba(255, 142, 183, 0.12);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-info {
    flex: 1;
}

.stat-label {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
    font-weight: 600;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text);
}

@media (max-width: 768px) {
    .page-content {
        gap: 2rem;
    }
    
    .server-info-section {
        max-width: 95%;
        padding: 0 1rem;
    }
    
    .server-info-card {
        padding: 2rem 1.5rem;
    }
    
    .server-address {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
    }
    
    .address-label {
        font-size: 1.1rem;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    
    .address-label i {
        font-size: 1.2rem;
    }
    
    .address-container {
        flex-direction: column;
        gap: 1rem;
    }
    
    #serverAddress {
        font-size: 1.2rem;
        padding: 0.75rem 1.5rem;
        min-width: auto;
        width: 100%;
        max-width: 280px;
    }
    
    .copy-btn {
        padding: 0.75rem 1.5rem;
        font-size: 0.9rem;
        min-width: 100px;
        width: 100%;
        max-width: 200px;
    }
    
    .server-stats {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    
    .stat-item {
        justify-content: center;
        text-align: center;
        gap: 1rem;
        padding: 0.75rem;
    }
    
    .stat-item i {
        font-size: 2.5rem
    }
}

/* 服务器状态详情样式 */
.server-status-section {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
}

.server-status-card {
    background: linear-gradient(135deg, var(--glass-bg), var(--color-card-bg));
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
}

.status-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.status-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
}

.status-title i {
    font-size: 1.8rem;
    color: var(--color-primary);
}

.refresh-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s var(--ease-smooth);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.refresh-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.refresh-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

.refresh-btn .spinning {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1.2rem 1.5rem;
    background: linear-gradient(135deg, var(--glass-bg), var(--color-card-bg));
    border-radius: var(--radius-lg);
