---
import Layout from '../layouts/Layout.astro';
import { websiteConfig } from '../config/website.config.js';
import PageTitle from '../components/PageTitle.astro';

const title = "主页";
const description = "欢迎来到我们的Minecraft服务器";
---

<Layout {title} {description}>
    <div class="page-container">
        <!-- 页面头部 -->
        <PageTitle pageTitle={websiteConfig.navigation.items.find(item => item.path === "/")?.pageTitle} />

        <!-- 主要内容区域 -->
        <main class="page-content">
            <!-- 服务器信息卡片 -->
            <section class="server-info-section">
                <div class="server-info-card card">
                    <!-- 服务器地址 -->
                    <div class="server-address">
                        <div class="address-label">
                            <i class="mdi mdi-network"></i>
                            <span>服务器地址</span>
                        </div>
                        <div class="address-container">
                            <code id="serverAddress">{websiteConfig.server.displayAddress}</code>
                            <button id="copyAddressBtn" class="copy-btn">
                                <i class="mdi mdi-content-copy"></i>
                                <span>复制</span>
                            </button>
                        </div>
                    </div>

                    <!-- 实时状态 -->
                    <div class="server-stats">
                        <div class="stat-item">
                            <i class="mdi mdi-account-group"></i>
                            <div class="stat-info">
                                <div class="stat-label">在线玩家</div>
                                <div class="stat-value" id="onlinePlayers">—</div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <i class="mdi mdi-cube"></i>
                            <div class="stat-info">
                                <div class="stat-label">游戏版本</div>
                                <div class="stat-value" id="gameVersion">{websiteConfig.server.version}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 服务器状态详情 -->
            <section class="server-status-section">
                <div class="server-status-card card">
                    <div class="status-header">
                        <h2 class="status-title">
                            <i class="mdi mdi-server"></i>
                            服务器实时状态
                        </h2>
                        <button id="refreshStatusBtn" class="refresh-btn">
                            <i class="mdi mdi-refresh"></i>
                            <span>刷新</span>
                        </button>
                    </div>

                    <!-- 状态指示器 -->
                    <div class="status-indicator">
                        <div class="server-icon-container">
                            <img id="serverIcon" class="server-icon" src="" alt="服务器图标" />
                        </div>
                        <div class="status-dot" id="serverStatusDot"></div>
                        <span class="status-text" id="serverStatusText">正在连接...</span>
                    </div>

                    <!-- 服务器信息 -->
                    <div class="server-details">
                        <div class="detail-row">
                            <div class="detail-label">服务器版本</div>
                            <div class="detail-value" id="versionDisplay">—</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">在线玩家</div>
                            <div class="detail-value" id="playersDisplay">—</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">服务器MOTD</div>
                            <div class="detail-value motd" id="motdDisplay">—</div>
                        </div>
                    </div>

                    <!-- 在线玩家列表 -->
                    <div class="players-section" id="playersSection">
                        <h3 class="players-title">当前在线玩家</h3>
                        <div class="players-list" id="playersList">
                            <div class="loading-players">加载中...</div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</Layout>

<script define:vars={{ apiEndpoint: websiteConfig.server.apiEndpoint, apiAddress: websiteConfig.server.apiAddress, port: websiteConfig.server.port }}>
// 服务器状态API调用
console.log('脚本开始执行...');
console.log('配置参数:', {apiEndpoint, apiAddress, port});

document.addEventListener('DOMContentLoaded', async function() {
    console.log('DOM已加载，开始初始化...');
    
    // 获取所有DOM元素
    const onlinePlayersEl = document.getElementById('onlinePlayers');
    const copyAddressBtn = document.getElementById('copyAddressBtn');
    const serverAddress = document.getElementById('serverAddress');
    const refreshStatusBtn = document.getElementById('refreshStatusBtn');
    const serverIcon = document.getElementById('serverIcon');
    const serverStatusDot = document.getElementById('serverStatusDot');
    const serverStatusText = document.getElementById('serverStatusText');
    const versionDisplay = document.getElementById('versionDisplay');
    const playersDisplay = document.getElementById('playersDisplay');
    const motdDisplay = document.getElementById('motdDisplay');
    const playersList = document.getElementById('playersList');
    
    console.log('DOM元素:', {onlinePlayersEl, copyAddressBtn, serverAddress, refreshStatusBtn});
    
    if (!onlinePlayersEl) {
        console.error('找不到onlinePlayers元素');
        return;
    }
    
    // 复制服务器地址功能
    if (copyAddressBtn) {
        copyAddressBtn.addEventListener('click', async function() {
            try {
                await navigator.clipboard.writeText(serverAddress.textContent);
                
                // 显示复制成功提示
                const originalText = copyAddressBtn.querySelector('span').textContent;
                copyAddressBtn.querySelector('span').textContent = '已复制';
                copyAddressBtn.classList.add('copied');
                
                // 显示 toast
                const toast = document.createElement('div');
                toast.className = 'copy-toast';
                toast.textContent = '✓ 地址已复制';
                document.body.appendChild(toast);
                requestAnimationFrame(() => toast.classList.add('show'));
                
                setTimeout(() => {
                    copyAddressBtn.querySelector('span').textContent = originalText;
                    copyAddressBtn.classList.remove('copied');
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 2000);
                
            } catch (err) {
                console.error('复制失败:', err);
            }
        });
    }
    
    // 手动刷新服务器状态
    if (refreshStatusBtn) {
        refreshStatusBtn.addEventListener('click', async function() {
            const icon = refreshStatusBtn.querySelector('i');
            
            // 添加旋转动画
            refreshStatusBtn.disabled = true;
            icon.classList.add('spinning');
            
            await fetchServerStatus();
            
            // 移除旋转动画
            refreshStatusBtn.disabled = false;
            icon.classList.remove('spinning');
        });
    }
    
    // 设置加载状态
    function setLoadingState() {
        if (serverStatusText) serverStatusText.textContent = '正在连接...';
        if (serverStatusDot) {
            serverStatusDot.className = 'status-dot';
            serverStatusDot.style.animation = 'pulse 2s infinite';
        }
        if (serverIcon) {
            serverIcon.src = '';
            serverIcon.style.display = 'none';
        }
        if (versionDisplay) versionDisplay.textContent = '—';
        if (playersDisplay) playersDisplay.textContent = '—';
        if (motdDisplay) motdDisplay.textContent = '加载中...';
        if (playersList) playersList.innerHTML = '<div class="loading-players">加载中...</div>';
    }
    
    // 设置离线状态
    function setOfflineState() {
        if (serverStatusText) serverStatusText.textContent = '服务器离线';
        if (serverStatusDot) {
            serverStatusDot.className = 'status-dot offline';
            serverStatusDot.style.animation = 'none';
        }
        if (serverIcon) {
            serverIcon.src = '';
            serverIcon.style.display = 'none';
        }
        if (versionDisplay) versionDisplay.textContent = '—';
        if (playersDisplay) playersDisplay.textContent = '0/?';
        if (motdDisplay) motdDisplay.textContent = '服务器当前不可用';
        if (playersList) playersList.innerHTML = '<div class="no-players">服务器暂无玩家在线(在线列表不显示假人)</div>';
    }
    
    // 更新服务器状态UI
    function updateServerStatusUI(data) {
        if (data.online) {
            if (serverStatusText) serverStatusText.textContent = '服务器在线';
            if (serverStatusDot) {
                serverStatusDot.className = 'status-dot online';
                serverStatusDot.style.animation = 'none';
            }
            
            // 更新服务器头像
            if (serverIcon && data.icon) {
                serverIcon.src = data.icon;
                serverIcon.style.display = 'block';
                serverIcon.alt = '服务器图标';
            }
            
            // 更新版本信息
            if (versionDisplay) versionDisplay.textContent = data.version?.name_clean || '—';
            
            // 更新玩家信息
            const onlinePlayers = data.players?.online || 0;
            const maxPlayers = data.players?.max || '?';
            if (playersDisplay) playersDisplay.textContent = `${onlinePlayers}/${maxPlayers}`;
            
            // 更新MOTD
            if (motdDisplay) motdDisplay.textContent = data.motd?.clean || '—';
            
            // 更新在线玩家列表（过滤掉Anonymous Player）
            if (playersList) {
                const players = data.players?.list || [];
                // 过滤掉匿名玩家和假人
                const realPlayers = players.filter(player => 
                    player.name_clean && 
                    player.name_clean !== 'Anonymous Player' && 
                    !player.name_clean.toLowerCase().includes('anonymous')
                );
                
                if (realPlayers.length > 0) {
                    const playerItems = realPlayers.map(player => 
                        `<div class="player-item">${player.name_clean}</div>`
                    ).join('');
                    playersList.innerHTML = playerItems;
                } else {
                    playersList.innerHTML = '<div class="no-players">服务器暂无玩家在线(在线列表不显示假人)</div>';
                }
            }
        } else {
            setOfflineState();
        }
    }
    
    // 获取服务器状态
    async function fetchServerStatus() {
        setLoadingState();
        
        try {
            const statusUrl = `https://mcapi.us/server/status?ip=${apiAddress}&port=${port}`;
            console.log('API请求URL:', statusUrl);
            
            const response = await fetch(statusUrl, {
                headers: { 'Accept': 'application/json' }
            });
            
            console.log('API响应状态:', response.status, response.statusText);
            
            if (!response.ok) {
                throw new Error(`API响应异常: ${response.status} ${response.statusText}`);
            }
            
            const raw = await response.json();
            console.log('API原始数据:', raw);
            
            // mcapi.us → mcstatus.io 格式转换
            const data = {
                online: raw.online || false,
                players: {
                    online: raw.players?.now || 0,
                    max: raw.players?.max || '?',
                    list: (raw.players?.sample || []).map(p => ({ name_clean: p.name }))
                },
                version: { name_clean: raw.server?.name || '—' },
                motd: { clean: raw.motd || '—' },
                icon: raw.favicon || null
            };
            
            // 更新在线玩家显示（顶部卡片）
            if (data.online) {
                const onlinePlayers = data.players?.online || 0;
                const maxPlayers = data.players?.max || '?';
                onlinePlayersEl.textContent = `${onlinePlayers}/${maxPlayers}`;
                console.log('在线玩家已更新:', onlinePlayersEl.textContent);
            } else {
                onlinePlayersEl.textContent = '离线';
            }
            
            // 更新完整状态显示
            updateServerStatusUI(data);
            
        } catch (error) {
            console.error('获取服务器状态失败:', error);
            onlinePlayersEl.textContent = '离线';
            setOfflineState();
        }
    }
    
    // 初始获取状态
    console.log('开始获取服务器状态...');
    await fetchServerStatus();
    
    // 每30秒更新一次状态
    setInterval(fetchServerStatus, 30000);
    console.log('定时器已设置，每30秒更新一次');
});
</script>

<style>
.page-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
}

.server-info-section {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
}

.server-info-card {
    text-align: center;
    background: linear-gradient(135deg, var(--glass-bg), var(--color-card-bg));
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
}

.server-address {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--glass-border);
}

.address-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
}

.address-label i {
    font-size: 1.5rem;
    color: var(--color-primary);
}

.address-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
}

#serverAddress {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 1rem 2rem;
    font-family: 'Courier New', monospace;
    font-size: 1.4rem;
    color: var(--color-text);
    font-weight: 700;
    min-width: 200px;
    text-align: center;
    box-shadow: var(--shadow-sm);
}

.copy-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s var(--ease-smooth);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 120px;
    justify-content: center;
}

.copy-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.copy-btn.copied {
    background: var(--color-success);
    transform: scale(1.05);
}

/* Toast 提示 */
.copy-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    background: var(--color-success);
    color: white;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: 1rem;
    box-shadow: var(--shadow-lg);
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s var(--ease-spring);
}

.copy-toast.show {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
}

.server-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
}

.stat-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-align: left;
    padding: 1rem;
    background: var(--glass-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
    transition: transform 0.3s var(--ease-smooth);
}

.stat-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.stat-item i {
    font-size: 3rem;
    color: var(--color-primary);
    flex-shrink: 0;
}

.stat-info {
    flex: 1;
}

.stat-label {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
    font-weight: 600;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text);
}

@media (max-width: 768px) {
    .page-content {
        gap: 2rem;
    }
    
    .server-info-section {
        max-width: 95%;
        padding: 0 1rem;
    }
    
    .server-info-card {
        padding: 2rem 1.5rem;
    }
    
    .server-address {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
    }
    
    .address-label {
        font-size: 1.1rem;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    
    .address-label i {
        font-size: 1.2rem;
    }
    
    .address-container {
        flex-direction: column;
        gap: 1rem;
    }
    
    #serverAddress {
        font-size: 1.2rem;
        padding: 0.75rem 1.5rem;
        min-width: auto;
        width: 100%;
        max-width: 280px;
    }
    
    .copy-btn {
        padding: 0.75rem 1.5rem;
        font-size: 0.9rem;
        min-width: 100px;
        width: 100%;
        max-width: 200px;
    }
    
    .server-stats {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    
    .stat-item {
        justify-content: center;
        text-align: center;
        gap: 1rem;
        padding: 0.75rem;
    }
    
    .stat-item i {
        font-size: 2.5rem
    }
}

/* 服务器状态详情样式 */
.server-status-section {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
}

.server-status-card {
    background: linear-gradient(135deg, var(--glass-bg), var(--color-card-bg));
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-xl);
}

.status-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.status-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
}

.status-title i {
    font-size: 1.8rem;
    color: var(--color-primary);
}

.refresh-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-full);
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s var(--ease-smooth);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.refresh-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.refresh-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

.refresh-btn .spinning {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--glass-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
}

.server-icon-container {
    flex-shrink: 0;
}

.server-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 2px solid var(--glass-border);
    background: var(--color-card-bg);
    object-fit: cover;
    transition: all 0.3s var(--ease-smooth);
}

.server-icon:hover {
    transform: scale(1.1);
    box-shadow: var(--shadow-md);
}

.status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-warning);
    animation: pulse 2s infinite;
}

.status-dot.online {
    background: var(--color-success);
    animation: breathe 2s ease-in-out infinite;
}

.status-dot.offline {
    background: var(--color-warning);
    animation: none;
}

@keyframes breathe {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(123, 239, 178, 0.6); }
    50% { opacity: 0.7; box-shadow: 0 0 8px 2px rgba(123, 239, 178, 0.3); }
}

.status-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.server-details {
    margin-bottom: 2rem;
}

.detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--glass-border);
}

.detail-row:last-child {
    border-bottom: none;
}

.detail-label {
    font-size: 1rem;
    color: var(--color-text-light);
    font-weight: 600;
}

.detail-value {
    font-size: 1.1rem;
    color: var(--color-text);
    font-weight: 700;
}

.motd {
    color: var(--color-primary);
    font-weight: 600;
    text-align: right;
    max-width: 300px;
    word-break: break-word;
}

.players-section {
    margin-top: 2rem;
}

.players-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
    text-align: center;
}

.players-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.75rem;
    max-height: 200px;
    overflow-y: auto;
    padding: 1rem;
    background: var(--glass-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
}

.player-item {
    background: var(--color-card-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    transition: all 0.3s var(--ease-smooth);
}

.player-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
}

.loading-players {
    text-align: center;
    color: var(--color-text-light);
    font-style: italic;
    grid-column: 1 / -1;
}

.no-players {
    text-align: center;
    color: var(--color-text-light);
    font-style: italic;
    grid-column: 1 / -1;
}

/* 响应式设计 */
@media (max-width: 768px) {
    .server-status-section {
        max-width: 95%;
        padding: 0 1rem;
    }
    
    .server-status-card {
        padding: 2rem 1.5rem;
    }
    
    .status-header {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
    }
    
    .status-title {
        justify-content: center;
        font-size: 1.3rem;
    }
    
    .detail-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        text-align: left;
    }
    
    .detail-value {
        align-self: flex-end;
    }
    
    .motd {
        text-align: left;
        max-width: 100%;
    }
    
    .players-list {
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        max-height: 150px;
    }
    
    .stat-label {
        font-size: 0.9rem;
    }
    
    .stat-value {
        font-size: 1.5rem;
    }
}

@media (min-width: 1200px) {
    .server-info-section {
        max-width: 900px;
    }
    
    .server-info-card {
        padding: 3rem;
    }
    
    .server-stats {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
    }
}

@media (max-width: 399px) {
    .server-info-card { padding: 1.5rem 1rem; }
