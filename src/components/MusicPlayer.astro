---
import { websiteConfig } from '../config/website.config.js';
---

<div id="music-player" class="music-player">
    <!-- 播放器按钮 -->
    <button id="music-toggle" class="music-toggle" aria-label="音乐播放器">
        <i class="mdi mdi-music"></i>
    </button>
    
    <!-- 遮罩层（手机端） -->
    <div id="music-overlay" class="music-overlay"></div>
    
    <!-- 播放器面板 -->
    <div id="music-panel" class="music-panel">
        <!-- 抽屉拖拽手柄（手机端） -->
        <div class="music-handle" id="music-handle"></div>
        
        <div class="music-header">
            <h3>🎵 云绒沐绵音乐盒</h3>
            <button id="music-close" class="music-close" aria-label="关闭">
                <i class="mdi mdi-close"></i>
            </button>
        </div>
        
        <div class="music-content">
            <div id="custom-music-player" class="custom-music-player">
                <!-- 当前播放 -->
                <div class="now-playing">
                    <div class="cover-wrap">
                        <img id="song-cover" src="" alt="封面" class="song-cover" />
                        <div class="cover-disc" id="cover-disc"></div>
                    </div>
                    <div class="now-info">
                        <div id="song-title" class="song-title">选择一首歌</div>
                        <div id="song-artist" class="song-artist">—</div>
                    </div>
                </div>
                
                <!-- 进度 -->
                <div class="progress-container">
                    <div class="time-display">
                        <span id="current-time">0:00</span>
                        <span id="duration">0:00</span>
                    </div>
                    <div class="progress-bar" id="progress-bar">
                        <div class="progress-fill" id="progress-fill"></div>
                        <div class="progress-thumb" id="progress-thumb"></div>
                    </div>
                </div>
                
                <!-- 控制按钮 -->
                <div class="control-row">
                    <div class="main-controls">
                        <button id="prev-btn" class="ctrl-btn" aria-label="上一首">
                            <i class="mdi mdi-skip-previous"></i>
                        </button>
                        <button id="play-btn" class="ctrl-btn ctrl-play" aria-label="播放">
                            <i class="mdi mdi-play"></i>
                        </button>
                        <button id="next-btn" class="ctrl-btn" aria-label="下一首">
                            <i class="mdi mdi-skip-next"></i>
                        </button>
                    </div>
                    <div class="side-controls">
                        <button id="mute-btn" class="ctrl-btn ctrl-sm" aria-label="音量">
                            <i class="mdi mdi-volume-high"></i>
                        </button>
                        <div class="volume-bar" id="volume-bar">
                            <div class="volume-fill" id="volume-fill"></div>
                        </div>
                    </div>
                </div>
                
                <!-- 歌单 -->
                <div class="playlist-container">
                    <div class="playlist-head">
                        <span>📋 播放列表</span>
                        <span id="playlist-count">0 首</span>
                    </div>
                    <input type="text" id="playlist-search" class="playlist-search" placeholder="🔍 搜歌..." />
                    <div id="playlist" class="playlist"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const isMobile = () => window.innerWidth < 640;

let playlist = [];
let currentIndex = 0;
let audio = null;
let isPlaying = false;
let isMuted = false;
let volume = 0.8;
let touchStartY = 0;
let panelOffset = 0;

async function loadPlaylist() {
    try {
        const res = await fetch('/assets/music/playlist.json');
        if (!res.ok) throw new Error('加载失败');
        const data = await res.json();
        playlist = data.songs || [];
        updatePlaylistUI();
        if (playlist.length > 0) loadSong(0);
    } catch (e) {
        console.error('歌单加载失败:', e);
    }
}

function loadSong(index) {
    if (index < 0 || index >= playlist.length || playlist.length === 0) return;
    currentIndex = index;
    const song = playlist[index];
    
    document.getElementById('song-title').textContent = song.title;
    document.getElementById('song-artist').textContent = song.artist;
    
    const cover = document.getElementById('song-cover');
    cover.src = song.cover || '/assets/music/default-cover.jpg';
    cover.onerror = () => { cover.src = '/assets/music/default-cover.jpg'; };
    
    audio.src = song.url;
    audio.load();
    updatePlaylistUI();
    scrollToCurrent();
}

function togglePlay() {
    if (!audio.src) return;
    if (isPlaying) audio.pause();
    else audio.play().catch(e => console.error('播放失败:', e));
}

function prevSong() {
    if (playlist.length <= 1) return;
    const idx = currentIndex > 0 ? currentIndex - 1 : playlist.length - 1;
    loadSong(idx);
    if (isPlaying) audio.play();
}

function nextSong() {
    if (playlist.length <= 1) return;
    const idx = currentIndex < playlist.length - 1 ? currentIndex + 1 : 0;
    loadSong(idx);
    if (isPlaying) audio.play();
}

function scrollToCurrent() {
    const item = document.querySelector('.playlist-item.active');
    if (item) item.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
}

function updatePlayButton() {
    document.querySelector('#play-btn i').className = isPlaying ? 'mdi mdi-pause' : 'mdi mdi-play';
    const disc = document.getElementById('cover-disc');
    if (disc) disc.classList.toggle('spinning', isPlaying);
}

function updateProgress() {
    document.getElementById('current-time').textContent = formatTime(audio.currentTime || 0);
    if (audio.duration && isFinite(audio.duration)) {
        const pct = (audio.currentTime / audio.duration) * 100;
        document.getElementById('progress-fill').style.width = pct + '%';
        document.getElementById('progress-thumb').style.left = pct + '%';
    }
}

function updateDuration() {
    document.getElementById('duration').textContent = formatTime(audio.duration || 0);
}

function formatTime(s) {
    if (!s || !isFinite(s)) return '0:00';
    return Math.floor(s / 60) + ':' + String(Math.floor(s % 60)).padStart(2, '0');
}

function handleSongEnd() { nextSong(); }

function toggleMute() {
    isMuted = !isMuted;
    audio.muted = isMuted;
    const i = document.querySelector('#mute-btn i');
    i.className = isMuted ? 'mdi mdi-volume-off' : (volume > 0.5 ? 'mdi mdi-volume-high' : 'mdi mdi-volume-medium');
}

function setVolume(v) {
    volume = Math.max(0, Math.min(1, v));
    audio.volume = volume;
    document.getElementById('volume-fill').style.width = (volume * 100) + '%';
}

function updatePlaylistUI(filter = '') {
    const el = document.getElementById('playlist');
    const count = document.getElementById('playlist-count');
    const filtered = filter ? playlist.filter(s =>
        s.title.toLowerCase().includes(filter) || s.artist.toLowerCase().includes(filter)
    ) : playlist;
    
    count.textContent = playlist.length + ' 首';
    if (filter) count.textContent = filtered.length + ' / ' + playlist.length + ' 首';
    
    el.innerHTML = filtered.map((song, i) => {
        const origIdx = playlist.indexOf(song);
        const active = origIdx === currentIndex;
        return `<div class="playlist-item${active ? ' active' : ''}" data-idx="${origIdx}">
            <span class="pli-idx">${active ? '▶' : origIdx + 1}</span>
            <span class="pli-title">${song.title}</span>
            <span class="pli-artist">${song.artist}</span>
        </div>`;
    }).join('') || '<div class="pli-empty">没有匹配的歌曲</div>';
    
    el.querySelectorAll('.playlist-item').forEach(item => {
        item.addEventListener('click', () => {
            loadSong(parseInt(item.dataset.idx));
            if (isPlaying) audio.play();
        });
    });
}

// Init
document.addEventListener('DOMContentLoaded', () => {
    audio = new Audio();
    audio.volume = volume;
    audio.addEventListener('loadedmetadata', updateDuration);
    audio.addEventListener('timeupdate', updateProgress);
    audio.addEventListener('ended', handleSongEnd);
    audio.addEventListener('play', () => { isPlaying = true; updatePlayButton(); document.querySelector('.cover-wrap')?.classList.add('playing'); });
    audio.addEventListener('pause', () => { isPlaying = false; updatePlayButton(); document.querySelector('.cover-wrap')?.classList.remove('playing'); });
    
    const toggle = document.getElementById('music-toggle');
    const panel = document.getElementById('music-panel');
    const close = document.getElementById('music-close');
    const overlay = document.getElementById('music-overlay');
    const handle = document.getElementById('music-handle');
    const search = document.getElementById('playlist-search');
    
    function open() {
        panel.classList.add('active');
        toggle.classList.add('active');
        if (isMobile()) { overlay.classList.add('active'); document.body.style.overflow = 'hidden'; }
    }
    function shut() {
        panel.classList.remove('active');
        toggle.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
        panel.style.transform = '';
        panelOffset = 0;
    }
    
    toggle.addEventListener('click', () => panel.classList.contains('active') ? shut() : open());
    close.addEventListener('click', shut);
    overlay.addEventListener('click', shut);
    
    // Touch drag to close
    if (handle) {
        handle.addEventListener('touchstart', e => {
            touchStartY = e.touches[0].clientY;
            panel.style.transition = 'none';
        });
        handle.addEventListener('touchmove', e => {
            const d = e.touches[0].clientY - touchStartY;
            if (d > 0) { panelOffset = d; panel.style.transform = `translateY(${d}px)`; }
        });
        handle.addEventListener('touchend', () => {
            panel.style.transition = 'transform 0.3s var(--ease-smooth)';
            if (panelOffset > 80) shut();
            else { panel.style.transform = ''; panelOffset = 0; }
        });
    }
    
    // Click outside (desktop)
    document.addEventListener('click', e => {
        const mp = document.getElementById('music-player');
        if (mp && !mp.contains(e.target) && panel.classList.contains('active') && !isMobile()) shut();
    });
    
    // Resize
    window.addEventListener('resize', () => {
        if (panel.classList.contains('active')) {
            isMobile() ? overlay.classList.add('active') : (overlay.classList.remove('active'), document.body.style.overflow = '');
        }
    });
    
    // Search
    search.addEventListener('input', () => updatePlaylistUI(search.value.toLowerCase().trim()));
    
    // Controls
    document.getElementById('play-btn').addEventListener('click', togglePlay);
    document.getElementById('prev-btn').addEventListener('click', prevSong);
    document.getElementById('next-btn').addEventListener('click', nextSong);
    document.getElementById('mute-btn').addEventListener('click', toggleMute);
    
    // Progress bar
    const pbar = document.getElementById('progress-bar');
    pbar.addEventListener('click', e => {
        if (!audio.src || !audio.duration) return;
        audio.currentTime = (e.clientX - pbar.getBoundingClientRect().left) / pbar.offsetWidth * audio.duration;
    });
    
    // Volume bar
    const vbar = document.getElementById('volume-bar');
    vbar.addEventListener('click', e => {
        setVolume((e.clientX - vbar.getBoundingClientRect().left) / vbar.offsetWidth);
    });
    
    // Load
    loadPlaylist();
});
</script>

<style>
/* ======== 基础 ======== */
.music-player { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; }
.music-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 998; opacity: 0; transition: opacity 0.3s; }
.music-overlay.active { opacity: 1; }

.music-toggle {
    width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    border: none; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; box-shadow: var(--shadow-lg); transition: all 0.3s var(--ease-spring); z-index: 1001;
}
.music-toggle:hover { transform: scale(1.12); box-shadow: var(--shadow-xl); }
.music-toggle.active { background: var(--color-accent); transform: rotate(45deg); }

/* 面板 */
.music-panel {
    position: absolute; bottom: 70px; right: 0; width: 370px; max-height: 560px;
    background: var(--color-card-bg); backdrop-filter: var(--glass-backdrop);
    border: 1px solid var(--glass-border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl); transform: translateY(16px) scale(0.92);
    opacity: 0; visibility: hidden; transition: all 0.3s var(--ease-spring);
    z-index: 1000; overflow: hidden; display: flex; flex-direction: column;
}
.music-panel.active { transform: translateY(0) scale(1); opacity: 1; visibility: visible; }
.music-handle { display: none; }

.music-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 1.2rem; border-bottom: 1px solid var(--glass-border); flex-shrink: 0;
    background: linear-gradient(135deg, rgba(255,142,183,0.08), rgba(255,209,102,0.06));
}
.music-header h3 { margin: 0; color: var(--color-text); font-size: 1rem; font-weight: 700; }
.music-close {
    background: none; border: none; color: var(--color-text-light); cursor: pointer;
    padding: 0.3rem; border-radius: var(--radius-full); font-size: 1.1rem;
    transition: all 0.3s;
}
.music-close:hover { background: var(--glass-bg); color: var(--color-text); }

.music-content {
    padding: 1rem 1.2rem; overflow-y: auto; flex: 1;
}
.music-content::-webkit-scrollbar { width: 4px; }
.music-content::-webkit-scrollbar-thumb { background: var(--color-primary); border-radius: 2px; }

/* 当前播放 */
.now-playing {
    display: flex; align-items: center; gap: 0.9rem; margin-bottom: 0.9rem;
}
.cover-wrap { position: relative; flex-shrink: 0; }
.cover-wrap::after {
    content: ''; position: absolute; inset: -4px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    opacity: 0; z-index: -1; transition: opacity 0.4s;
    filter: blur(8px);
}
.cover-wrap.playing::after { opacity: 0.5; }
.song-cover {
    width: 64px; height: 64px; border-radius: 50%; object-fit: cover;
    box-shadow: var(--shadow-md); border: 2px solid var(--glass-border);
    transition: all 0.4s var(--ease-smooth);
}
.cover-wrap:hover .song-cover { transform: scale(1.08); }
.cover-wrap.playing .song-cover { box-shadow: 0 0 20px rgba(255,142,183,0.3); }
.now-info { flex: 1; min-width: 0; }
.song-title {
    font-size: 0.95rem; font-weight: 700; color: var(--color-text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.15rem;
}
.song-artist {
    font-size: 0.78rem; color: var(--color-text-light);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* 进度条 */
.progress-container { margin-bottom: 0.7rem; }
.time-display { display: flex; justify-content: space-between; font-size: 0.68rem; color: var(--color-text-light); margin-bottom: 0.25rem; }
.progress-bar {
    width: 100%; height: 6px; background: var(--glass-bg); border-radius: 3px;
    cursor: pointer; position: relative;
}
.progress-fill {
    height: 100%; background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    border-radius: 3px; width: 0; transition: width 0.15s linear;
}
.progress-thumb {
    position: absolute; top: -4px; width: 14px; height: 14px; border-radius: 50%;
    background: white; box-shadow: var(--shadow-sm); left: -7px;
    opacity: 0; transition: opacity 0.2s;
}
.progress-bar:hover .progress-thumb { opacity: 1; }

/* 控制按钮 */
.control-row {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;
}
.main-controls { display: flex; align-items: center; gap: 0.5rem; }
.side-controls { display: flex; align-items: center; gap: 0.5rem; }
.ctrl-btn {
    background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-full);
    color: var(--color-text); cursor: pointer; padding: 0.5rem; display: flex;
    align-items: center; justify-content: center; font-size: 1.05rem;
    transition: all 0.25s var(--ease-smooth);
}
.ctrl-btn:hover { background: var(--color-primary); color: white; transform: scale(1.08); }
.ctrl-btn.ctrl-play {
    width: 42px; height: 42px; background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: white; border: none; font-size: 1.2rem;
}
.ctrl-btn.ctrl-play:hover { transform: scale(1.14); }
.ctrl-btn.ctrl-sm { padding: 0.35rem; font-size: 0.9rem; }
.volume-bar {
    width: 50px; height: 4px; background: var(--glass-bg); border-radius: 2px; cursor: pointer;
}
.volume-fill { height: 100%; background: var(--color-primary); border-radius: 2px; width: 80%; }

/* 歌单 */
.playlist-container { border-top: 1px solid var(--glass-border); padding-top: 0.6rem; }
.playlist-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.4rem; font-size: 0.78rem; font-weight: 600; color: var(--color-text);
}
#playlist-count { font-size: 0.65rem; color: var(--color-text-light); }
.playlist-search {
    width: 100%; padding: 0.4rem 0.65rem; margin-bottom: 0.4rem;
    border: 1px solid var(--glass-border); border-radius: var(--radius-sm);
    background: var(--glass-bg); color: var(--color-text); font-size: 0.75rem;
    outline: none; transition: border-color 0.3s;
}
.playlist-search:focus { border-color: var(--color-primary); }
.playlist {
    max-height: 180px; overflow-y: auto; border-radius: var(--radius-sm);
    background: var(--glass-bg); border: 1px solid var(--glass-border);
}
.playlist::-webkit-scrollbar { width: 4px; }
.playlist::-webkit-scrollbar-thumb { background: var(--color-primary); border-radius: 2px; }

.playlist-item {
    display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.65rem;
    cursor: pointer; transition: all 0.2s; border-bottom: 1px solid var(--glass-border);
    font-size: 0.76rem;
}
.playlist-item:nth-child(even) { background: rgba(255,255,255,0.04); }
.playlist-item:nth-child(odd)  { background: rgba(255,255,255,0.1); }
.playlist-item:last-child { border-bottom: none; }
.playlist-item:hover { background: var(--glass-bg) !important; }
.playlist-item.active {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)) !important;
    color: white;
}
.pli-idx { width: 20px; text-align: center; font-size: 0.7rem; flex-shrink: 0; opacity: 0.6; }
.pli-title { flex: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pli-artist { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; opacity: 0.7; font-size: 0.7rem; text-align: right; }
.pli-empty { text-align: center; padding: 1.5rem; color: var(--color-text-light); font-size: 0.8rem; }

/* ======== 平板 ======== */
@media (min-width: 640px) and (max-width: 1024px) {
    .music-player { bottom: 1.5rem; right: 1.5rem; }
    .music-toggle { width: 50px; height: 50px; font-size: 1.25rem; }
    .music-panel { width: 340px; max-height: 520px; bottom: 62px; }
    .music-header { padding: 0.8rem 1.1rem; }
    .music-content { padding: 0.9rem 1.1rem; }
    .song-cover { width: 56px; height: 56px; }
    .song-title { font-size: 0.9rem; }
    .ctrl-btn.ctrl-play { width: 38px; height: 38px; font-size: 1.1rem; }
    .playlist { max-height: 160px; }
}

/* ======== 手机：底部抽屉 ======== */
@media (max-width: 639px) {
    .music-overlay { display: block; }
    .music-player { bottom: 1rem; right: 1rem; }
    .music-toggle { width: 48px; height: 48px; font-size: 1.2rem; }
    .music-panel {
        position: fixed; bottom: 0; left: 0; right: 0; width: 100%; max-height: 62vh;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        transform: translateY(100%); opacity: 1; visibility: visible;
        box-shadow: 0 -8px 40px rgba(0,0,0,0.25);
    }
    .music-panel.active { transform: translateY(0); }
    .music-handle {
        display: block; width: 36px; height: 5px; background: var(--color-border);
        border-radius: 3px; margin: 10px auto 0; flex-shrink: 0;
    }
    .music-header { padding: 0.75rem 1.1rem; }
    .music-header h3 { font-size: 0.95rem; }
    .music-content { padding: 0.75rem 1.1rem; }
    .song-cover { width: 54px; height: 54px; }
    .song-title { font-size: 0.9rem; }
    .ctrl-btn { padding: 0.45rem; font-size: 1rem; }
    .ctrl-btn.ctrl-play { width: 38px; height: 38px; font-size: 1.15rem; }
    .volume-bar { width: 45px; }
    .playlist { max-height: 150px; }
}

/* ======== 小平手机 ======== */
@media (max-width: 399px) {
    .music-player { bottom: 0.6rem; right: 0.6rem; }
    .music-toggle { width: 40px; height: 40px; font-size: 1rem; }
    .music-panel { max-height: 55vh; }
    .music-handle { width: 26px; height: 3px; margin-top: 6px; }
    .music-header { padding: 0.5rem 0.8rem; }
    .music-header h3 { font-size: 0.82rem; }
    .music-content { padding: 0.5rem 0.8rem; }
    .song-cover { width: 44px; height: 44px; }
    .song-title { font-size: 0.82rem; }
    .song-artist { font-size: 0.7rem; }
    .ctrl-btn { padding: 0.35rem; font-size: 0.85rem; }
    .ctrl-btn.ctrl-play { width: 30px; height: 30px; font-size: 0.9rem; }
    .ctrl-btn.ctrl-sm { padding: 0.3rem; font-size: 0.75rem; }
    .volume-bar { width: 35px; height: 3px; }
    .playlist { max-height: 100px; }
    .playlist-item { padding: 0.3rem 0.5rem; font-size: 0.7rem; }
    .playlist-search { font-size: 0.7rem; padding: 0.3rem 0.5rem; }
}
</style>
