---
import { websiteConfig } from '../config/website.config.js';
---

<div id="music-player" class="music-player">
    <!-- 播放器按钮 -->
    <button id="music-toggle" class="music-toggle" aria-label="音乐播放器">
        <i class="mdi mdi-music"></i>
    </button>
    
    <!-- 遮罩层（手机端） -->
    <div id="music-overlay" class="music-overlay"></div>
    
    <!-- 播放器界面 -->
    <div id="music-panel" class="music-panel">
        <!-- 抽屉拖拽手柄（手机端） -->
        <div class="music-handle" id="music-handle"></div>
        
        <div class="music-header">
            <h3>🎵 音乐播放器</h3>
            <button id="music-close" class="music-close" aria-label="关闭播放器">
                <i class="mdi mdi-close"></i>
            </button>
        </div>
        
        <div class="music-content">
            <!-- 自定义音乐播放器 -->
            <div id="custom-music-player" class="custom-music-player">
                <div class="player-controls">
                    <div class="song-info">
                        <img id="song-cover" src="" alt="歌曲封面" class="song-cover">
                        <div class="song-details">
                            <div id="song-title" class="song-title">选择歌曲</div>
                            <div id="song-artist" class="song-artist">-</div>
                        </div>
                    </div>
                    
                    <div class="progress-container">
                        <div class="time-display">
                            <span id="current-time">0:00</span>
                            <span id="duration">0:00</span>
                        </div>
                        <div class="progress-bar" id="progress-bar">
                            <div class="progress-fill" id="progress-fill"></div>
                        </div>
                    </div>
                    
                    <div class="control-buttons">
                        <button id="prev-btn" class="control-btn" aria-label="上一首">
                            <i class="mdi mdi-skip-previous"></i>
                        </button>
                        <button id="play-btn" class="control-btn play-btn" aria-label="播放">
                            <i class="mdi mdi-play"></i>
                        </button>
                        <button id="next-btn" class="control-btn" aria-label="下一首">
                            <i class="mdi mdi-skip-next"></i>
                        </button>
                        <div class="volume-control">
                            <button id="mute-btn" class="control-btn" aria-label="静音">
                                <i class="mdi mdi-volume-high"></i>
                            </button>
                            <div class="volume-bar" id="volume-bar">
                                <div class="volume-fill" id="volume-fill"></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="playlist-container">
                    <div class="playlist-header">
                        <h4>播放列表</h4>
                        <span id="playlist-count">0 首歌曲</span>
                    </div>
                    <div id="playlist" class="playlist">
                        <!-- 播放列表将在这里动态生成 -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// 检测是否为移动端
const isMobile = () => window.innerWidth < 640;

// 音乐播放器状态
let currentSong = {
    id: 0,
    title: '选择歌曲',
    artist: '-',
    cover: '',
    url: '',
    duration: 0
};

let playlist = [];
let currentIndex = 0;
let audio = null;
let isPlaying = false;
let isMuted = false;
let volume = 0.8;
let isShuffled = false;
let isRepeating = 0;
let touchStartY = 0;
let panelOffset = 0;

// 初始化音乐播放器
document.addEventListener('DOMContentLoaded', () => {
    const musicToggle = document.getElementById('music-toggle');
    const musicPanel = document.getElementById('music-panel');
    const musicClose = document.getElementById('music-close');
    const musicOverlay = document.getElementById('music-overlay');
    const musicHandle = document.getElementById('music-handle');
    
    // 初始化音频元素
    audio = new Audio();
    audio.volume = volume;
    
    audio.addEventListener('loadedmetadata', updateDuration);
    audio.addEventListener('timeupdate', updateProgress);
    audio.addEventListener('ended', handleSongEnd);
    audio.addEventListener('play', () => { isPlaying = true; updatePlayButton(); });
    audio.addEventListener('pause', () => { isPlaying = false; updatePlayButton(); });
    
    initUIEvents();
    loadPlaylist();
    
    // 打开/关闭面板
    function openPanel() {
        musicPanel.classList.add('active');
        musicToggle.classList.add('active');
        if (isMobile()) {
            musicOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    }
    
    function closePanel() {
        musicPanel.classList.remove('active');
        musicToggle.classList.remove('active');
        musicOverlay.classList.remove('active');
        document.body.style.overflow = '';
        panelOffset = 0;
        musicPanel.style.transform = '';
    }
    
    if (musicToggle && musicPanel) {
        musicToggle.addEventListener('click', () => {
            if (musicPanel.classList.contains('active')) {
                closePanel();
            } else {
                openPanel();
            }
        });
        
        musicClose.addEventListener('click', closePanel);
        musicOverlay.addEventListener('click', closePanel);
        
        // 手机端下拉关闭
        if (musicHandle) {
            musicHandle.addEventListener('touchstart', (e) => {
                touchStartY = e.touches[0].clientY;
                musicPanel.style.transition = 'none';
            });
            
            musicHandle.addEventListener('touchmove', (e) => {
                const delta = e.touches[0].clientY - touchStartY;
                if (delta > 0) {
                    panelOffset = delta;
                    musicPanel.style.transform = `translateY(${delta}px)`;
                }
            });
            
            musicHandle.addEventListener('touchend', () => {
                musicPanel.style.transition = 'transform 0.3s var(--ease-smooth)';
                if (panelOffset > 80) {
                    closePanel();
                } else {
                    musicPanel.style.transform = '';
                    panelOffset = 0;
                }
            });
        }
        
        // 点击外部关闭（桌面端）
        document.addEventListener('click', (e) => {
            const musicPlayer = document.getElementById('music-player');
            if (musicPlayer && !musicPlayer.contains(e.target) && musicPanel.classList.contains('active') && !isMobile()) {
                closePanel();
            }
        });
    }
    
    // 窗口大小变化时更新
    window.addEventListener('resize', () => {
        if (musicPanel.classList.contains('active')) {
            if (isMobile()) {
                musicOverlay.classList.add('active');
            } else {
                musicOverlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        }
    });
});

function initUIEvents() {
    const playBtn = document.getElementById('play-btn');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const muteBtn = document.getElementById('mute-btn');
    const progressBar = document.getElementById('progress-bar');
    const volumeBar = document.getElementById('volume-bar');
    
    playBtn.addEventListener('click', togglePlay);
    prevBtn.addEventListener('click', previousSong);
    nextBtn.addEventListener('click', nextSong);
    muteBtn.addEventListener('click', toggleMute);
    
    progressBar.addEventListener('click', (e) => {
        if (!audio.src) return;
        const rect = progressBar.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        audio.currentTime = percent * audio.duration;
    });
    
    volumeBar.addEventListener('click', (e) => {
        const rect = volumeBar.getBoundingClientRect();
        const percent = (e.clientX - rect.left) / rect.width;
        setVolume(percent);
    });
}

async function loadPlaylist() {
    try {
        const response = await fetch('https://api.i-meto.com/meting/api?server=netease&type=playlist&id=5186526688');
        if (!response.ok) throw new Error('API请求失败');
        
        const data = await response.json();
        playlist = data.map((song, index) => ({
            id: song.id || index,
            title: song.name || song.title || '未知歌曲',
            artist: song.artist || song.author || '未知艺术家',
            cover: song.pic || '',
            url: song.url || '',
            duration: song.duration || 0
        }));
        
        updatePlaylistUI();
        if (playlist.length > 0) loadSong(0);
    } catch (error) {
        console.error('加载播放列表失败:', error);
        loadFallbackPlaylist();
    }
}

function loadFallbackPlaylist() {
    playlist = [
        {
            id: 1, title: '深海之息', artist: 'Youzee Music',
            cover: 'https://p1.music.126.net/PhKOqFtljgHDDpKYM2ADUA==/109951169858309716.jpg',
            url: '/assets/music/深海之息.m4a', duration: 146
        },
        {
            id: 2, title: 'Stay Here Forever', artist: 'Jewel',
            cover: 'https://imgessl.kugou.com/stdmusic/480/20250904/20250904025411117893.jpg',
            url: '/assets/music/Jewel - Stay Here Forever.m4a', duration: 180
        }
    ];
    updatePlaylistUI();
    if (playlist.length > 0) loadSong(0);
}

function loadSong(index) {
    if (index < 0 || index >= playlist.length) return;
    currentIndex = index;
    currentSong = { ...playlist[index] };
    document.getElementById('song-title').textContent = currentSong.title;
    document.getElementById('song-artist').textContent = currentSong.artist;
    document.getElementById('song-cover').src = currentSong.cover;
    audio.src = currentSong.url;
    audio.load();
    updatePlaylistUI();
}

function togglePlay() {
    if (!audio.src) return;
    if (isPlaying) { audio.pause(); }
    else { audio.play().catch(e => console.error('播放失败:', e)); }
}

function previousSong() {
    if (playlist.length <= 1) return;
    const newIndex = currentIndex > 0 ? currentIndex - 1 : playlist.length - 1;
    loadSong(newIndex);
    if (isPlaying) audio.play();
}

function nextSong() {
    if (playlist.length <= 1) return;
    let newIndex;
    if (isShuffled) {
        do { newIndex = Math.floor(Math.random() * playlist.length); }
        while (newIndex === currentIndex && playlist.length > 1);
    } else {
        newIndex = currentIndex < playlist.length - 1 ? currentIndex + 1 : 0;
    }
    loadSong(newIndex);
    if (isPlaying) audio.play();
}

function handleSongEnd() {
    if (isRepeating === 1) { audio.currentTime = 0; audio.play(); }
    else if (isRepeating === 2 || currentIndex < playlist.length - 1) { nextSong(); }
}

function toggleMute() {
    isMuted = !isMuted;
    audio.muted = isMuted;
    const icon = document.querySelector('#mute-btn i');
    icon.className = isMuted ? 'mdi mdi-volume-off' : (volume > 0.5 ? 'mdi mdi-volume-high' : 'mdi mdi-volume-medium');
}

function setVolume(value) {
    volume = Math.max(0, Math.min(1, value));
    audio.volume = volume;
    document.getElementById('volume-fill').style.width = (volume * 100) + '%';
    const icon = document.querySelector('#mute-btn i');
    if (!isMuted) {
        icon.className = volume === 0 ? 'mdi mdi-volume-off' : (volume > 0.5 ? 'mdi mdi-volume-high' : 'mdi mdi-volume-medium');
    }
}

function updatePlayButton() {
    document.querySelector('#play-btn i').className = isPlaying ? 'mdi mdi-pause' : 'mdi mdi-play';
}

function updateDuration() {
    document.getElementById('duration').textContent = formatTime(audio.duration);
}

function updateProgress() {
    document.getElementById('current-time').textContent = formatTime(audio.currentTime);
    if (audio.duration) {
        document.getElementById('progress-fill').style.width = (audio.currentTime / audio.duration * 100) + '%';
    }
}

function formatTime(seconds) {
    if (!seconds || !isFinite(seconds)) return '0:00';
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return mins + ':' + (secs < 10 ? '0' : '') + secs;
}

function updatePlaylistUI() {
    const playlistElement = document.getElementById('playlist');
    const countElement = document.getElementById('playlist-count');
    countElement.textContent = playlist.length + ' 首歌曲';
    
    playlistElement.innerHTML = playlist.map((song, index) => `
        <div class="playlist-item ${index === currentIndex ? 'active' : ''}" data-index="${index}">
            <div class="playlist-content">
                <span class="playlist-title">${song.title}</span>
                <span class="playlist-separator">-</span>
                <span class="playlist-artist">${song.artist}</span>
            </div>
        </div>
    `).join('');
    
    playlistElement.querySelectorAll('.playlist-item').forEach((item, index) => {
        item.addEventListener('click', () => {
            loadSong(index);
            if (isPlaying) audio.play();
        });
    });
}
</script>

<style>
/* ======== 基础布局 ======== */
.music-player {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 999;
}

/* 遮罩层（手机端） */
.music-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 998;
    opacity: 0;
    transition: opacity 0.3s var(--ease-smooth);
}
.music-overlay.active {
    opacity: 1;
}

/* 开关按钮 */
.music-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    box-shadow: var(--shadow-lg);
    transition: all 0.3s var(--ease-smooth);
    position: relative;
    z-index: 1001;
}
.music-toggle:hover {
    transform: scale(1.1);
    box-shadow: var(--shadow-xl);
}
.music-toggle.active {
    background: var(--color-accent);
}

/* 面板 — 桌面端：右下弹出 */
.music-panel {
    position: absolute;
    bottom: 70px;
    right: 0;
    width: 360px;
    max-height: 520px;
    background: var(--color-card-bg);
    backdrop-filter: var(--glass-backdrop);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    transform: translateY(16px) scale(0.92);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s var(--ease-spring);
    z-index: 1000;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}
.music-panel.active {
    transform: translateY(0) scale(1);
    opacity: 1;
    visibility: visible;
}

/* 拖拽手柄（手机端 — 默认隐藏） */
.music-handle {
    display: none;
}

/* 头部 */
.music-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--glass-border);
    flex-shrink: 0;
}
.music-header h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 700;
}
.music-close {
    background: none;
    border: none;
    color: var(--color-text-light);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: var(--radius-full);
    font-size: 1.1rem;
    transition: all 0.3s var(--ease-smooth);
}
.music-close:hover {
    background: var(--glass-bg);
    color: var(--color-text);
}

/* 内容区 */
.music-content {
    padding: 1rem 1.25rem;
    overflow-y: auto;
    flex: 1;
}
.music-content::-webkit-scrollbar { width: 4px; }
.music-content::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 2px;
}

/* 播放信息 */
.custom-music-player { width: 100%; }
.player-controls { padding-bottom: 0.75rem; border-bottom: 1px solid var(--glass-border); margin-bottom: 0.5rem; }

.song-info {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
}
.song-cover {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    object-fit: cover;
    margin-right: 0.75rem;
    box-shadow: var(--shadow-sm);
}
.song-details { flex: 1; min-width: 0; }
.song-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.song-artist {
    font-size: 0.8rem;
    color: var(--color-text-light);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* 进度条 */
.progress-container { margin-bottom: 0.75rem; }
.time-display {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--color-text-light);
    margin-bottom: 0.3rem;
}
.progress-bar {
    width: 100%;
    height: 5px;
    background: var(--glass-bg);
    border-radius: 3px;
    cursor: pointer;
}
.progress-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 3px;
    width: 0%;
    transition: width 0.1s linear;
}

/* 控制按钮 */
.control-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
}
.control-btn {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-full);
    color: var(--color-text);
    cursor: pointer;
    padding: 0.45rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: all 0.25s var(--ease-smooth);
}
.control-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: scale(1.08);
}
.control-btn.play-btn {
    width: 38px;
    height: 38px;
    background: var(--color-primary);
    color: white;
}
.control-btn.play-btn:hover {
    background: var(--color-accent);
    transform: scale(1.12);
}
.volume-control {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
}
.volume-bar {
    width: 50px;
    height: 4px;
    background: var(--glass-bg);
    border-radius: 2px;
    cursor: pointer;
}
.volume-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 2px;
    width: 80%;
}

/* 播放列表 */
.playlist-container { padding-top: 0.25rem; }
.playlist-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.4rem;
}
.playlist-header h4 {
    margin: 0;
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
}
#playlist-count {
    font-size: 0.65rem;
    color: var(--color-text-light);
    background: var(--glass-bg);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-full);
}
.playlist {
    max-height: 150px;
    overflow-y: auto;
    border-radius: var(--radius-sm);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
}
.playlist::-webkit-scrollbar { width: 4px; }
.playlist::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 2px;
}
.playlist-item {
    display: flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    cursor: pointer;
    transition: all 0.25s var(--ease-smooth);
    border-bottom: 1px solid var(--glass-border);
}
.playlist-item:nth-child(even) { background: rgba(255,255,255,0.06); }
.playlist-item:nth-child(odd)  { background: rgba(255,255,255,0.12); }
.playlist-item:last-child { border-bottom: none; }
.playlist-item:hover {
    background: var(--glass-bg) !important;
    transform: translateX(4px);
}
.playlist-item.active {
    background: var(--color-primary) !important;
    color: white;
    border-left: 3px solid var(--color-accent);
}
.playlist-content {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
    gap: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
}
.playlist-title {
    font-size: 0.78rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
}
.playlist-separator { font-size: 0.7rem; opacity: 0.5; flex-shrink: 0; }
.playlist-artist {
    font-size: 0.72rem;
    opacity: 0.7;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 0.8;
    min-width: 0;
}

/* ======== 平板 (640–1024px) ======== */
@media (min-width: 640px) and (max-width: 1024px) {
    .music-player {
        bottom: 1.5rem;
        right: 1.5rem;
    }
    .music-toggle {
        width: 50px;
        height: 50px;
        font-size: 1.3rem;
    }
    .music-panel {
        width: 320px;
        max-height: 480px;
        bottom: 62px;
    }
}

/* ======== 手机 (<640px)：底部抽屉 ======== */
@media (max-width: 639px) {
    .music-overlay { display: block; }
    
    .music-player {
        bottom: 1rem;
        right: 1rem;
    }
    .music-toggle {
        width: 48px;
        height: 48px;
        font-size: 1.25rem;
    }
    
    /* 面板变底部抽屉 */
    .music-panel {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        max-height: 65vh;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        transform: translateY(100%);
        opacity: 1;
        visibility: visible;
        z-index: 1000;
        box-shadow: 0 -8px 32px rgba(0,0,0,0.15);
    }
    .music-panel.active {
        transform: translateY(0);
    }
    
    /* 拖拽手柄 */
    .music-handle {
        display: block;
        width: 36px;
        height: 4px;
        background: var(--color-border);
        border-radius: 2px;
        margin: 8px auto 0;
        flex-shrink: 0;
    }
    
    .music-header {
        padding: 0.75rem 1rem;
    }
    .music-header h3 { font-size: 0.95rem; }
    .music-content {
        padding: 0.75rem 1rem;
    }
    
    .song-cover {
        width: 48px;
        height: 48px;
    }
    .song-title { font-size: 0.9rem; }
    .song-artist { font-size: 0.75rem; }
    
    .control-btn { padding: 0.4rem; font-size: 0.95rem; }
    .control-btn.play-btn { width: 34px; height: 34px; }
    .volume-bar { width: 45px; }
    
    .playlist { max-height: 120px; }
    .playlist-item { padding: 0.4rem 0.7rem; }
    .playlist-title { font-size: 0.74rem; }
    .playlist-artist { font-size: 0.68rem; }
}

/* ======== 小平手机 (<400px) ======== */
@media (max-width: 399px) {
    .music-player {
        bottom: 0.75rem;
        right: 0.75rem;
    }
    .music-toggle {
        width: 42px;
        height: 42px;
